#!/usr/bin/osascript -l JavaScript

// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function fileExists(path) {
  return $.NSFileManager.defaultManager.fileExistsAtPath(path)
}

function fileModified(path) {
  const attributes = $.NSFileManager.defaultManager
    .attributesOfItemAtPathError(path, undefined)

  if (!attributes || !attributes.js || !attributes.js["NSFileModificationDate"])
    return 0

  return attributes.js["NSFileModificationDate"].js.getTime()
}

function deleteFile(path) {
  return $.NSFileManager.defaultManager.removeItemAtPathError(path, undefined)
}

function writeFile(path, text) {
  $(text).writeToFileAtomicallyEncodingError(path, true, $.NSUTF8StringEncoding, undefined)
}

function readFile(path) {
  const content = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined)
  return (content && content.js) || ""
}

function ensureDirectory(path) {
  const fileManager = $.NSFileManager.defaultManager

  if (!fileManager.fileExistsAtPath(path))
    fileManager.createDirectoryAtPathWithIntermediateDirectoriesAttributesError(path, true, undefined, undefined)
}

function parseSession(data) {
  if (Array.isArray(data)) return { title: null, messages: data }
  if (data && Array.isArray(data.messages)) return { title: data.title || null, messages: data.messages }
  return { title: null, messages: [] }
}

function readSession(path) {
  const chatString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
  return parseSession(JSON.parse(chatString))
}

function readJson(path, fallback) {
  if (!fileExists(path)) return fallback

  try {
    const jsonString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
    return JSON.parse(jsonString)
  } catch {
    return fallback
  }
}

function writeSession(path, session) {
  if (!session.title) {
    writeFile(path, JSON.stringify(session.messages))
    return
  }

  writeFile(path, JSON.stringify({
    title: session.title,
    messages: session.messages
  }))
}

function appendChat(path, message) {
  const session = readSession(path)
  session.messages = session.messages.concat(message)
  writeSession(path, session)
}

function chatLabels() {
  const user = (envVar("chat_user_label") || "You").trim() || "You"
  const assistant = (envVar("chat_assistant_label") || "Assistant").trim() || "Assistant"
  return { user, assistant }
}

function demoteMarkdownHeadings(text, bump = 3) {
  if (!text) return text

  return text.replace(/^(#{1,6})(\s)/gm, (_, hashes, space) => {
    const level = Math.min(hashes.length + bump, 6)
    return "#".repeat(level) + space
  })
}

function isHangingPreamble(text) {
  const t = (text || "").trim()
  if (!t) return true
  if (/[:：]\s*$/.test(t)) return true
  if (t.length > 140) return false
  const resultMarker = /(因为|所以|结论|建议|步骤|方法|答案|如下|http|无法|不能|没有|不支持|你可以|要不|或者|第一|结果是|^\s*\d+\.)/m
  if (resultMarker.test(t)) return false
  const sentences = t.split(/[。.!！?？\n]+/).map(s => s.trim()).filter(Boolean)
  if (sentences.length === 0) return true
  const intentVerb = /(看下|看一下|看看|先看|查下|查一下|查查|搜下|搜一下|抓下|抓一下|试下|试一下|我试|去查|去看|去搜|去抓|并行查|查几个|搜几个|目录结构|目录里有|目录有|稍等|接下来|马上|这就|我来|让我|我先|我直接|我去)/
  return sentences.every(s => intentVerb.test(s))
}

const HANGING_PREAMBLE_NOTE = "（说明：我每条回复都是完整的，没有“回复后再继续执行”的能力，也无法联网搜索或运行 baoyu/外部脚本。请把链接或正文直接贴进来，我可帮你写入本地文件 / Obsidian 或做本地处理；要查实时新闻请告诉我已知事实，我基于它继续。）"

function withHangingPreambleFallback(text) {
  if (!isHangingPreamble(text)) return text
  const base = (text || "").trim()
  return base ? `${base}\n\n${HANGING_PREAMBLE_NOTE}` : HANGING_PREAMBLE_NOTE
}

function formatUserLabel(labels) {
  return `# ⊙ ${labels.user}`
}

function formatAssistantLabel(labels) {
  return `# ⊚ ${labels.assistant}`
}

function markdownChat(messages, ignoreLastInterrupted = true) {
  const labels = chatLabels()

  return messages.reduce((accumulator, current, index, allMessages) => {
    if (current["role"] === "assistant")
      return `${accumulator}${demoteMarkdownHeadings(current["content"])}\n\n`

    if (current["role"] === "user") {
      const userMessage = `${formatUserLabel(labels)}\n\n${current["content"]}\n\n${formatAssistantLabel(labels)}`
      const userTwice = allMessages[index + 1]?.["role"] === "user"
      const lastMessage = index === allMessages.length - 1

      return userTwice || (lastMessage && !ignoreLastInterrupted) ?
        `${accumulator}${userMessage}\n\n[Answer Interrupted]\n\n` :
        `${accumulator}${userMessage}\n\n`
    }

    return accumulator
  }, "")
}

function markdownSession(session, ignoreLastInterrupted = true) {
  const header = session.title ? `## ⌖ ${session.title}\n\n---\n\n` : ""
  return `${header}${markdownChat(session.messages, ignoreLastInterrupted)}`
}

function markdownSessionWithDraft(chatFile, draftText) {
  const session = readSession(chatFile)
  const messages = session.messages.slice()
  if (messages.length > 0 && messages[messages.length - 1]["role"] === "user" && draftText)
    messages.push({ role: "assistant", content: draftText })

  return markdownSession({ title: session.title, messages }, false)
}

function outputTokenLimit() {
  const configured = parseInt(envVar("max_output_tokens"))
  return Number.isFinite(configured) && configured > 0 ? configured : 4096
}

function streamMaxSeconds(timeoutSeconds) {
  const configured = parseInt(envVar("stream_max_seconds"))
  if (Number.isFinite(configured) && configured > 0) return configured
  return Math.min(Math.max(timeoutSeconds * 4, 120), 300)
}

function streamIdleSeconds(timeoutSeconds) {
  const configured = parseInt(envVar("stream_idle_seconds"))
  if (Number.isFinite(configured) && configured > 0) return configured
  return Math.max(timeoutSeconds * 3, 90)
}

function skillsPrompt(query) {
  if (skillsPrompt._cache && skillsPrompt._cache.query === (query || "")) {
    return skillsPrompt._cache.value
  }
  const result = runLocalAgentWithArguments(["--skills-prompt", query || ""])
  let value = ""
  if (result && typeof result === "string" && result.trim().length > 0) {
    value = result.trim()
  }
  skillsPrompt._cache = { query: query || "", value: value }
  return value
}

function memoryPrompt() {
  const legacy = `${envVar("alfred_workflow_data")}/memory.json`
  const memDir = `${envVar("alfred_workflow_data")}/memories`
  if (fileExists(legacy) && !fileExists(`${memDir}/MEMORY.md`) && !fileExists(`${memDir}/USER.md`))
    runLocalAgentWithArguments(["--migrate-memory"])

  const result = runLocalAgentWithArguments(["--memory-prompt"])
  if (result && result.prompt && result.prompt.trim().length > 0)
    return result.prompt

  return ""
}

function soulPrompt() {
  runLocalAgentWithArguments(["--ensure-soul"])

  const result = runLocalAgentWithArguments(["--soul-prompt"])
  if (result && result.prompt && result.prompt.trim().length > 0)
    return result.prompt

  return ""
}

function runtimeGuardPrompt() {
