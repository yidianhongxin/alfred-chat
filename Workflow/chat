    providerName: provider,
    apiKey: "",
    endpoint: "",
    model: "",
    supportsThinkingParam: false,
    apiStyle: "openai"
  }
}

function chatPayload(model, messages, stream, supportsThinkingParam) {
  const payload = {
    model: model,
    messages: messages,
    stream: stream,
    max_tokens: outputTokenLimit()
  }

  if (supportsThinkingParam) payload.thinking = { type: "disabled" }
  return payload
}

function runCompleteChat(chatFile, typedQuery, provider, systemPrompt, contextChat, timeoutSeconds) {
  const result = runChatCompletion(provider, {
    model: provider.model,
    messages: systemPrompt ?
      [{ role: "system", content: systemPrompt }].concat(contextChat) :
      contextChat,
    stream: false
  }, timeoutSeconds)

  if (result.error) {
    return JSON.stringify({
      response: result.error,
      behaviour: { response: "replacelast", scroll: "end" }
    })
  }

  const assistantText = result.content || ""
  appendChat(chatFile, { role: "assistant", content: assistantText })
  maybeTriggerBackgroundReview(chatFile)
  maybeIndexSession()

  const session = readSession(chatFile)
  return JSON.stringify({
    response: markdownSession(session, false),
    footer: provider.apiStyle === "anthropic" ? "Anthropic 使用非流式回复" : undefined,
    behaviour: { scroll: "end" }
  })
}

function startStream(apiEndpoint, apiKey, model, systemPrompt, contextChat, streamFile, pidStreamFile, timeoutSeconds, supportsThinkingParam = true) {
  $.NSFileManager.defaultManager.createFileAtPathContentsAttributes(streamFile, undefined, undefined)

  const messages = systemPrompt ?
    [{ role: "system", content: systemPrompt }].concat(contextChat) :
    contextChat

  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/curl")
  var curlArgsStream = [
    apiEndpoint,
    "--max-time", streamMaxSeconds(timeoutSeconds).toString(),
    "--silent", "--no-buffer",
    "--header", "Content-Type: application/json"
  ]
  if (apiKey) curlArgsStream.push("--header", "Authorization: Bearer " + apiKey)
  curlArgsStream.push("--data", JSON.stringify(chatPayload(model, messages, true, supportsThinkingParam)))
  curlArgsStream.push("--output", streamFile)
  task.arguments = curlArgsStream

  task.standardOutput = stdout
  task.launchAndReturnError(false)
  writeFile(pidStreamFile, task.processIdentifier.toString())
}

function readStream(streamFile, chatFile, pidStreamFile, timeoutSeconds) {
  const streamMarker = envVar("stream_marker") === "1"
  const streamContents = $.NSString.stringWithContentsOfFileEncodingError(streamFile, $.NSUTF8StringEncoding, undefined)
  const streamString = (streamContents && streamContents.js) || ""

  if (streamMarker) return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: "0" },
    response: "…",
    behaviour: { response: "append" }
  })

  if (streamString.startsWith("{")) {
    try {
      const parsedError = JSON.parse(streamString)
      const errorMessage = parsedError["error"]?.["message"] || parsedError["message"]

      if (errorMessage) {
        deleteFile(streamFile)
        deleteFile(pidStreamFile)

        return JSON.stringify({
          response: errorMessage,
          variables: { streaming_now: "0", stream_marker: "0" },
          behaviour: { response: "replacelast" }
        })
      }

      throw "Could not determine error message"
    } catch {
      console.log(streamString)

      return JSON.stringify({
        response: streamString,
        variables: { streaming_now: "0", stream_marker: "0" },
        behaviour: { response: "replacelast" }
      })
    }
  }

  const chunks = streamString
    .split("\n")
    .filter(item => item)
    .map(item => item.replace(/^data: /, ""))
    .flatMap(item => { try { return JSON.parse(item) } catch { return [] } })

  const responseText = chunks
    .map(item => item["choices"]?.[0]?.["delta"]?.["content"])
    .filter(item => item)
    .join("")
  const finishReason = chunks.slice(-1)[0]?.["choices"]?.[0]?.["finish_reason"]

  if (!finishReason) {
    const idleLimitMs = streamIdleSeconds(timeoutSeconds) * 1000
    const stalled = new Date().getTime() - fileModified(streamFile) > idleLimitMs

    if (stalled) {
      if (responseText.length > 0) appendChat(chatFile, { role: "assistant", content: responseText })

      deleteFile(streamFile)
      deleteFile(pidStreamFile)

      const session = readSession(chatFile)
      return JSON.stringify({
        response: `${demoteMarkdownHeadings(responseText)} [Connection Stalled]`,
        footer: "流式连接中断，回复可能不完整；可输入「继续」让助手接着写",
        variables: { streaming_now: "0", stream_marker: "0" },
        behaviour: { response: "replacelast", scroll: "end" }
      })
    }

    if (streamString.length === 0) return JSON.stringify({
      rerun: 0.1,
      variables: { streaming_now: true }
    })

    return JSON.stringify({
      rerun: 0.1,
      variables: { streaming_now: true, stream_marker: "0" },
      response: demoteMarkdownHeadings(responseText),
      behaviour: { response: "replacelast", scroll: "end" }
    })
  }

  const finalText = finishReason === "stop" ? withHangingPreambleFallback(responseText) : responseText
  appendChat(chatFile, { role: "assistant", content: finalText })
  deleteFile(streamFile)
  deleteFile(pidStreamFile)
  maybeTriggerBackgroundReview(chatFile)
  maybeIndexSession()

  const footerText = (function() {
    switch (finishReason) {
      case "length": return "已达输出长度上限，可输入「继续」补全剩余内容"
      case "content_filter": return "部分内容因安全策略被过滤"
    }
  })()

  return JSON.stringify({
    response: demoteMarkdownHeadings(finalText),
    footer: footerText,
    variables: { streaming_now: "0", stream_marker: "0" },
    behaviour: { response: "replacelast", scroll: "end" }
  })
}

function countTurns(messages) {
  return messages.filter(message => message["role"] === "user").length
}

function popLastTurns(messages, count) {
  let result = messages.slice()

  for (let step = 0; step < count && result.length > 0; step++) {
    if (result[result.length - 1]["role"] === "assistant") result.pop()
    if (result.length > 0 && result[result.length - 1]["role"] === "user") result.pop()
  }

  return result
}

function trimToTurn(messages, turnNumber) {
  if (turnNumber <= 0) return []

  let turn = 0

  for (let index = 0; index < messages.length; index++) {
    if (messages[index]["role"] !== "user") continue

    turn++
    if (turn !== turnNumber) continue

    const next = messages[index + 1]
    return messages.slice(0, next?.["role"] === "assistant" ? index + 2 : index + 1)
  }

  return messages
}

function turnListText(messages) {
  const users = messages.filter(message => message["role"] === "user")

  if (users.length === 0) return "No turns yet."

  return users.map((message, index) => {
    const preview = message["content"].replace(/\s+/g, " ").slice(0, 48)
    return `${index + 1}. ${preview}${message["content"].length > 48 ? "…" : ""}`
  }).join("\n")
}


// --- /model command ---
const VALID_MODELS = Object.freeze(["MiniMax-M3", "deepseek-v4-flash", "deepseek-v4-pro"])

function handleModel(chatFile, typedQuery) {
  const modelMatch = typedQuery.match(/^\/model(?:\s+(.*))?$/i)
  if (!modelMatch) return null

  const session = readSession(chatFile)
  const newModel = (modelMatch[1] || "").trim()

  if (!newModel || !VALID_MODELS.some(m => m.toLowerCase() === newModel.toLowerCase())) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: "Available: " + VALID_MODELS.join(" · ") + ". Usage: /model MiniMax-M3",
      behaviour: { scroll: "end" }
    })
  }

  const canonical = VALID_MODELS.find(m => m.toLowerCase() === newModel.toLowerCase())

  if (canonical === "MiniMax-M3") {
    Application("com.runningwithcrayons.Alfred").setConfiguration("minimax_model", { toValue: canonical, inWorkflow: envVar("alfred_workflow_bundleid") })
    Application("com.runningwithcrayons.Alfred").setConfiguration("chat_provider", { toValue: "minimax", inWorkflow: envVar("alfred_workflow_bundleid") })
  } else {
    Application("com.runningwithcrayons.Alfred").setConfiguration("deepseek_model", { toValue: canonical, inWorkflow: envVar("alfred_workflow_bundleid") })
    Application("com.runningwithcrayons.Alfred").setConfiguration("chat_provider", { toValue: "deepseek", inWorkflow: envVar("alfred_workflow_bundleid") })
  }

  return JSON.stringify({
    response: markdownSession(session, false),
    footer: "Model switched to " + canonical,
    behaviour: { scroll: "end" }
  })
}

function handleRename(chatFile, typedQuery) {
  const renameMatch = typedQuery.match(/^\/rename(?:\s+(.*))?$/i)
  if (!renameMatch) return null

  const session = readSession(chatFile)
  const newTitle = (renameMatch[1] || "").trim()

  if (!newTitle) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: "Usage: /rename Your session title",
      behaviour: { scroll: "end" }
    })
  }

  session.title = newTitle
  writeSession(chatFile, session)

  return JSON.stringify({
    response: markdownSession(session, false),
    footer: `Session renamed to: ${newTitle}`,
    behaviour: { scroll: "end" }
  })
}

function handleRewind(chatFile, typedQuery) {
  const rewindMatch = typedQuery.match(/^\/rewind(?:\s+(.*))?$/i)
  if (!rewindMatch) return null

  const session = readSession(chatFile)
  const argument = (rewindMatch[1] || "").trim()
  const totalTurns = countTurns(session.messages)

  if (!argument || argument.toLowerCase() === "list") {
    return JSON.stringify({
      response: `${markdownSession(session, false)}\n\n## Turns\n\n${turnListText(session.messages)}`,
      footer: "Usage: /rewind 1 · /rewind 3 · /rewind to 2",
      behaviour: { scroll: "end" }
    })
  }

  const toMatch = argument.match(/^to\s+(\d+)$/i)
  if (toMatch) {
    const targetTurn = parseInt(toMatch[1], 10)

    if (targetTurn < 1 || targetTurn > totalTurns) {
      return JSON.stringify({
        response: markdownSession(session, false),
        footer: `Turn must be between 1 and ${totalTurns}`,
        behaviour: { scroll: "end" }
      })
    }

    session.messages = trimToTurn(session.messages, targetTurn)
    writeSession(chatFile, session)

    return JSON.stringify({
      response: markdownSession(session, false),
      footer: `Rewound to turn ${targetTurn} of ${totalTurns}`,
      behaviour: { scroll: "end" }
    })
  }

  const removeCount = parseInt(argument, 10)

  if (!removeCount || removeCount < 1) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: "Usage: /rewind 1 · /rewind 3 · /rewind to 2",
      behaviour: { scroll: "end" }
    })
  }

  if (removeCount > totalTurns) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: `Only ${totalTurns} turn(s) available`,
      behaviour: { scroll: "end" }
    })
  }

  session.messages = popLastTurns(session.messages, removeCount)
  writeSession(chatFile, session)

  return JSON.stringify({
    response: markdownSession(session, false),
    footer: `Removed last ${removeCount} turn(s)`,
    behaviour: { scroll: "end" }
  })
}

function parseExportIntent(query) {
  const trimmed = query.trim()
  if (!trimmed) return null

  const commandMatch = trimmed.match(/^\/export(?:\s+(.*))?$/i)
  if (commandMatch) return { customName: (commandMatch[1] || "").trim() }

  const isExportIntent =
    /导出(?:当前|本次|本|这段)?(?:对话|聊天|会话)/.test(trimmed) ||
    /导出到\s*(?:ob|obsidian)\b/i.test(trimmed) ||
    /^export(?:\s+to\s+obsidian|\s+(?:this|current)?\s*(?:chat|conversation)\b)/i.test(trimmed)

  if (!isExportIntent) return null

  const namePatterns = [
    /(?:命名为|取名(?:为)?|标题(?:为)?|叫做|称作)[:：]\s*(.+)$/i,
    /(?:named|name(?:d)?|title)[:：\s]\s*(.+)$/i,
    /[，,]\s*(?:命名为|取名(?:为)?|标题(?:为)?)[:：]?\s*(.+)$/i,
  ]

  for (const pattern of namePatterns) {
    const match = trimmed.match(pattern)
    if (match) return { customName: match[1].trim() }
  }

  return { customName: "" }
}

function exportSessionToObsidian(chatFile, customName) {
  const session = readSession(chatFile)

  if (session.messages.length === 0) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: "Nothing to export in this session",
      behaviour: { scroll: "end" }
    })
  }

  const { vaultPath, exportDir } = obsidianExportPaths()

  if (!fileExists(vaultPath)) {
    return JSON.stringify({
      response: markdownSession(session, false),
      footer: `Obsidian vault not found: ${vaultPath}`,
      behaviour: { scroll: "end" }
    })
  }

  ensureDirectory(exportDir)

  const { title, body } = exportMarkdownSession(session)
  const exportTitle = customName || title
  const filePath = uniqueExportPath(exportDir, exportTitle)
  const { providerName, model } = resolveProvider()
  const created = new Date().toISOString()
  const note = [
    "---",
    `title: ${yamlScalar(exportTitle)}`,
    `created: ${created}`,
    "tags:",
    "  - alfred-chat",
    `provider: ${yamlScalar(providerName)}`,
    `model: ${yamlScalar(model)}`,
    "---",
    "",
    body
  ].join("\n")

  writeFile(filePath, note)

  return JSON.stringify({
    response: `${markdownSession(session, false)}\n\n**已存入 done**`,
    footer: "已存入 done",
    behaviour: { scroll: "end" }
  })
}

function handleExport(chatFile, typedQuery) {
  const intent = parseExportIntent(typedQuery)
  if (!intent) return null

  return exportSessionToObsidian(chatFile, intent.customName)
}

function _pad2(n) { return n.toString().padStart(2, "0") }

function ensureFreshChat(chatFile) {
  // 当 env new_chat=1 时: 把当前 session 移到 archive,写空 chat.json。
  // 减法版: 不依赖 plist 写文件节点,一处处理 cmd+回车 和 Add Context 两条路径。
  if (envVar("new_chat") !== "1") return
  // rename 关键字 → 最近对话 → 触发 new_chat trigger → 8296D113 强制覆盖 new_chat=1
  // 此时 F87E8DE0 已经把所选 archive 移到 chat.json,这里再归档会把刚 load 的对话清空 → 空白。
  if (envVar("replace_with_chat")) return
  if (!fileExists(chatFile)) {
    writeFile(chatFile, "[]")
    return
  }
  let isEmpty = false
  try {
    const raw = $.NSString.stringWithContentsOfFileEncodingError(chatFile, $.NSUTF8StringEncoding, undefined).js
    const current = JSON.parse(raw || "[]")
    isEmpty = Array.isArray(current) ? current.length === 0 : (current.messages || []).length === 0
  } catch {}
  if (isEmpty) return
  const dataDir = envVar("alfred_workflow_data")
  const archiveDir = `${dataDir}/archive`
  const now = new Date()
  const ts = `${now.getFullYear()}.${_pad2(now.getMonth() + 1)}.${_pad2(now.getDate())}.${_pad2(now.getHours())}.${_pad2(now.getMinutes())}.${_pad2(now.getSeconds())}`
  $.NSFileManager.defaultManager.createDirectoryAtPathWithIntermediateDirectoriesAttributesError(archiveDir, true, undefined, undefined)
  const uid = $.NSProcessInfo.processInfo.globallyUniqueString.js.split("-")[0]
  const archived = `${archiveDir}/${ts}-${uid}.json`
  try { $.NSFileManager.defaultManager.moveItemAtPathToPathError(chatFile, archived, undefined) } catch {}
  writeFile(chatFile, "[]")
}

// Main
function run(argv) {
  // new_chat / replace_with_chat 都是一次性信号：runMain 顶部的 ensureFreshChat
  // 已消费 new_chat 完成归档；F87E8DE0 已消费 replace_with_chat 完成 archive↔chat 切换。
  // 这里在最终输出里把两者都清成 "0"/""，避免它们在 Text View 变量作用域里长期残留，
  // 否则下次 Cmd+回车 会因为 replace_with_chat 残留而跳过归档，表现就是新会话没清空。
  const out = runMain(argv)
  try {
    const parsed = JSON.parse(out)
    parsed.variables = Object.assign({}, parsed.variables, {
      new_chat: "0",
      replace_with_chat: ""
    })
    return JSON.stringify(parsed)
  } catch {
    return out
  }
}

function runMain(argv) {
  const typedQuery = argv[0]
  const maxContext = parseInt(envVar("max_context"))
  const timeoutSeconds = parseInt(envVar("timeout_seconds"))
  const configuredSystemPrompt = envVar("system_prompt")
  const chatFile = `${envVar("alfred_workflow_data")}/chat.json`
  const pidStreamFile = `${envVar("alfred_workflow_cache")}/pid.txt`
  const streamFile = `${envVar("alfred_workflow_cache")}/stream.txt`
  const streamingNow = envVar("streaming_now") === "1"

  ensureFreshChat(chatFile)


  if (streamingNow) return readStream(streamFile, chatFile, pidStreamFile, timeoutSeconds)

  const session = readSession(chatFile)

  if (fileExists(streamFile)) return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: true },
    response: markdownSession(session, true),
    behaviour: { scroll: "end" }
  })

  if (typedQuery.length > 0) triggerCuratorTick()

  if (typedQuery.length === 0) return JSON.stringify({
    response: markdownSession(session, false),
    behaviour: { scroll: "end" }
  })

  const modelResponse = handleModel(chatFile, typedQuery)
  if (modelResponse) return modelResponse

  const renameResponse = handleRename(chatFile, typedQuery)
  if (renameResponse) return renameResponse

  const rewindResponse = handleRewind(chatFile, typedQuery)
  if (rewindResponse) return rewindResponse

  const exportResponse = handleExport(chatFile, typedQuery)
  if (exportResponse) return exportResponse

  const localControlResponse = handleLocalFileControl(chatFile, typedQuery)
  if (localControlResponse) return localControlResponse

  const provider = resolveProvider()
  const systemPrompt = composeSystemPrompt(configuredSystemPrompt, typedQuery)

  if (providerRequiresApiKey(provider) && (!provider.apiKey || provider.apiKey.length === 0)) {
    return JSON.stringify({
      response: `**${provider.providerName} API Key is missing.**\n\nOpen Alfred Preferences → Workflows → Alfred Chat → Configure, then add your API key.`,
      behaviour: { response: "replacelast", scroll: "end" }
    })
  }

  const modelToolResponse = handleModelToolUse(chatFile, typedQuery, provider, systemPrompt, timeoutSeconds)
  if (modelToolResponse) return modelToolResponse

  const appendQuery = { role: "user", content: typedQuery }
  const ongoingMessages = session.messages.concat(appendQuery)
  const contextChat = ongoingMessages.slice(-maxContext)

  appendChat(chatFile, appendQuery)

  if (provider.apiStyle === "anthropic") {
    return runCompleteChat(chatFile, typedQuery, provider, systemPrompt, contextChat, timeoutSeconds)
  }

  startStream(provider.endpoint, provider.apiKey, provider.model, systemPrompt, contextChat, streamFile, pidStreamFile, timeoutSeconds, provider.supportsThinkingParam)

  return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: true },
    response: markdownSession({ title: session.title, messages: ongoingMessages })
  })
}
