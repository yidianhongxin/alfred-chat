    return {
      provider: "openai_custom",
      providerName: "Custom OpenAI",
      apiKey: envVar("openai_custom_api_key") || "",
      endpoint: base.replace(/\/+$/, "") + "/chat/completions",
      model: envVar("openai_custom_model") || "gpt-4o",
      supportsThinkingParam: false,
      apiStyle: "openai"
    }
  }

  if (provider === "minimax") {
    const customEndpoint = envVar("minimax_api_endpoint")
