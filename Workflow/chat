function runWorkflowPython(scriptName, args, timeoutSeconds) {
  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [workflowScriptPath(scriptName)].concat(args || [])
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  const limitMs = (timeoutSeconds || 30) * 1000
  while (task.running && waitedMs < limitMs) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return { error: "Python 脚本执行超时" }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return { error: errorOutput || output }

  try {
    return JSON.parse(output)
  } catch {
    return { error: output || "Python 脚本返回异常" }
  }
}

function runProviderBridgeComplete(provider, payload, timeoutSeconds) {
  const bridgePayload = {
    provider: provider.provider,
    model: payload.model || provider.model,
