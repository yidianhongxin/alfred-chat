#!/usr/bin/osascript -l JavaScript

// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function fileExists(path) {
  return $.NSFileManager.defaultManager.fileExistsAtPath(path)
}

function fileModified(path) {
  const attributes = $.NSFileManager.defaultManager
    .attributesOfItemAtPathError(path, undefined)

  if (!attributes || !attributes.js || !attributes.js["NSFileModificationDate"])
    return 0

  return attributes.js["NSFileModificationDate"].js.getTime()
}

function deleteFile(path) {
  return $.NSFileManager.defaultManager.removeItemAtPathError(path, undefined)
}

function writeFile(path, text) {
  $(text).writeToFileAtomicallyEncodingError(path, true, $.NSUTF8StringEncoding, undefined)
}

function readFile(path) {
  const content = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined)
  return (content && content.js) || ""
}

function ensureDirectory(path) {
  const fileManager = $.NSFileManager.defaultManager

  if (!fileManager.fileExistsAtPath(path))
    fileManager.createDirectoryAtPathWithIntermediateDirectoriesAttributesError(path, true, undefined, undefined)
}

function parseSession(data) {
  if (Array.isArray(data)) return { title: null, messages: data }
  if (data && Array.isArray(data.messages)) return { title: data.title || null, messages: data.messages }
  return { title: null, messages: [] }
}

function readSession(path) {
  const chatString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
  return parseSession(JSON.parse(chatString))
}

function readJson(path, fallback) {
  if (!fileExists(path)) return fallback

  try {
    const jsonString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
    return JSON.parse(jsonString)
  } catch {
    return fallback
  }
}

function writeSession(path, session) {
  if (!session.title) {
    writeFile(path, JSON.stringify(session.messages))
    return
  }

  writeFile(path, JSON.stringify({
    title: session.title,
    messages: session.messages
  }))
}

function appendChat(path, message) {
  const session = readSession(path)
  session.messages = session.messages.concat(message)
  writeSession(path, session)
}

function chatLabels() {
  const user = (envVar("chat_user_label") || "You").trim() || "You"
  const assistant = (envVar("chat_assistant_label") || "Assistant").trim() || "Assistant"
  return { user, assistant }
}

function demoteMarkdownHeadings(text, bump = 3) {
  if (!text) return text

  return text.replace(/^(#{1,6})(\s)/gm, (_, hashes, space) => {
    const level = Math.min(hashes.length + bump, 6)
    return "#".repeat(level) + space
  })
}

function isHangingPreamble(text) {
  const t = (text || "").trim()
  if (!t) return true
  if (/[:：]\s*$/.test(t)) return true
  if (t.length > 140) return false
  const resultMarker = /(因为|所以|结论|建议|步骤|方法|答案|如下|http|无法|不能|没有|不支持|你可以|要不|或者|第一|结果是|^\s*\d+\.)/m
  if (resultMarker.test(t)) return false
  const sentences = t.split(/[。.!！?？\n]+/).map(s => s.trim()).filter(Boolean)
  if (sentences.length === 0) return true
  const intentVerb = /(看下|看一下|看看|先看|查下|查一下|查查|搜下|搜一下|抓下|抓一下|试下|试一下|我试|去查|去看|去搜|去抓|并行查|查几个|搜几个|目录结构|目录里有|目录有|稍等|接下来|马上|这就|我来|让我|我先|我直接|我去)/
  return sentences.every(s => intentVerb.test(s))
}

const HANGING_PREAMBLE_NOTE = "" // W8: 已支持联网,无需"无法联网"提示

function withHangingPreambleFallback(text) {
  if (!isHangingPreamble(text)) return text
  const base = (text || "").trim()
  return base ? `${base}\n\n${HANGING_PREAMBLE_NOTE}` : HANGING_PREAMBLE_NOTE
}

// [W9.1] M3 推理模型在没 tool 支持时, 会 mimic 训练数据输出 <toolcall>...</toolcall> 文本。
// 这不是真工具调用,但 chat 脚本之前直接当 assistant 文本存盘 → 用户看 hallucinate + 答空。
// 这里 detect + 真调 + 重答, 解决:
//   1) M3 hallucinate bug — 用户看到真搜索结果而非 <toolcall> JSON
//   2) 联网能力兜底 — 就算 system prompt 没强调"用搜索", M3 自带的 web_search 幻觉也被真跑
function isHallucinatedToolCall(text) {
  return /<\s*tool[_]?call\b/i.test(text || "")
}

// 解析 M3 输出的 <toolcall>{"name":"web_search","arguments":{...}}</toolcall>
// 返回 [{name, arguments}] 数组 (可能 0..N 个)
function extractHallucinatedToolCalls(text) {
  const out = []
  if (!text) return out
  // 先尝试成对 <toolcall>...</toolcall>
  const paired = [...text.matchAll(/<\s*tool[_]?call\s*[^>]*>([\s\S]*?)<\s*\/\s*tool[_]?call\s*>/gi)]
  for (const m of paired) {
    const body = (m[1] || "").trim()
    // 提取第一个 { ... } JSON 对象 (容错)
    const objMatch = body.match(/\{[\s\S]*\}/)
    if (!objMatch) continue
    try {
      out.push(JSON.parse(objMatch[0]))
    } catch {}
  }
  if (out.length > 0) return out

  // 容错: 多个相邻 <toolcall>{...}{...}</toolcall> 没分别包
  const blob = text.match(/<\s*tool[_]?call\s*[^>]*>([\s\S]*?)<\s*\/\s*tool[_]?call\s*>/i)
  if (blob) {
    const body = blob[1]
    const objRe = /\{(?:[^{}]|\{[^{}]*\})*\}/g
    const objs = body.match(objRe) || []
    for (const o of objs) {
      try { out.push(JSON.parse(o)) } catch {}
    }
  }
  return out
}

// 真跑 M3 hallucinate 的工具 (通过 local_agent --tool)
// 返回 [{name, ok, text}]
function runHallucinatedToolCalls(toolCalls) {
  const results = []
  for (const tc of toolCalls || []) {
    const rawName = (tc && (tc.name || tc.tool)) || ""
    const name = rawName.toLowerCase()
    const args = (tc && (tc.arguments || tc.args)) || {}

    let localTool = null
    if (name === "web_search" || name === "websearch" || name === "search") {
      localTool = { tool: "web_search", args: { query: args.query || args.q || "" } }
    } else if (name === "web_fetch" || name === "webfetch" || name === "fetch") {
      localTool = { tool: "web_fetch", args: { url: args.url || "" } }
    }

    if (!localTool) {
      results.push({ name: rawName || "unknown", ok: false, text: `(不支持的幻觉工具: ${rawName || "?"},已跳过)` })
      continue
    }

    try {
      const r = runLocalAgentWithArguments(["--tool", JSON.stringify(localTool)])
      if (r && r.handled) {
        results.push({ name: rawName, ok: r.status === "success", text: r.assistant_text || "" })
      } else {
        results.push({ name: rawName, ok: false, text: "(工具未处理)" })
      }
    } catch (e) {
      results.push({ name: rawName, ok: false, text: `(执行异常: ${e && e.message ? e.message : e})` })
    }
  }
  return results
}

// 把工具结果拼成 user message, 第二次调 LLM, 返回 finalText
// 不重答的话原样返回 null
function maybeResolveHallucinatedToolCall(chatFile, assistantText, provider, systemPrompt, contextChat, timeoutSeconds) {
  if (!isHallucinatedToolCall(assistantText)) return null

  const toolCalls = extractHallucinatedToolCalls(assistantText)
  if (toolCalls.length === 0) {
    return `(W9.1 检测到 <toolcall> 标记但无法解析任何工具调用)\n\n${assistantText}`
  }

  // append 原 hallucinate 文本 (留作 debug)
  appendChat(chatFile, { role: "assistant", content: assistantText })

  // 真跑工具
  const results = runHallucinatedToolCalls(toolCalls)
  const summary = results.map(r =>
    r.ok
      ? `[${r.name} 成功] ${r.text}`
      : `[${r.name} 失败] ${r.text}`
  ).join("\n\n")

  const toolResultMsg = `【W9.1 自动执行工具】\n${summary}\n\n请基于以上工具结果回答用户。`
  appendChat(chatFile, { role: "user", content: toolResultMsg })

  // 重新调 LLM
  const reSession = readSession(chatFile)
  const reContext = reSession.messages.slice(-(parseInt(envVar("max_context")) || 40))
  const messages = systemPrompt ?
    [{ role: "system", content: systemPrompt }].concat(reContext) :
    reContext

  const reResult = runChatCompletion(provider, {
    model: provider.model,
    messages: messages,
    stream: false
  }, timeoutSeconds * 2)  // 二次调用放宽 timeout

  if (reResult.error) {
    return `(W9.1 工具已跑, 但 LLM 重答失败: ${reResult.error})\n\n${summary}`
  }
  return reResult.content || ""
}

// [W9 continuation] 用户说"go on" / "继续" / "接着说" — 读 pending 拼成新一轮 user message
function isContinuationQuery(text) {
  const t = (text || "").trim()
  // 严格匹配"go on"作整个词, 避免 "go online" 等误中
  return /^(?:go on|continue|please continue|go ahead)\b/i.test(t)
    || /^(继续|接着说|接着|继续说)$/.test(t)
}

function handleContinuation(chatFile, typedQuery, provider, systemPrompt, timeoutSeconds) {
  // 1. 读 pending
  const contResult = runLocalAgentWithArguments(["--continuation-get"])
  const continuation = contResult && contResult.continuation
  if (!continuation) {
    return responseWithConversation(chatFile, typedQuery,
      "没有待续的对话(可能已完成或已过期)。",
      "无 pending")
  }

  // 2. 拼 user message: 上一轮 query + 上一轮 partial + 用户 go on 指令
  const lastQuery = continuation.last_query || ""
  const lastPartial = continuation.last_assistant_partial || ""
  const continuePrompt = [
    "【W9 continuation · 用户请求续答】",
    "上一轮用户问题:",
    lastQuery,
    "",
    "你上一轮(未完成)的回答:",
    lastPartial,
    "",
    "现在请接着上一轮继续回答 — 不要重复已完成的部分,直接接续。"
  ].join("\n")

  // 3. 把 continue_prompt 作为新一轮 user message, 调 LLM
  appendChat(chatFile, { role: "user", content: continuePrompt })
  const session = readSession(chatFile)
  const ongoingMessages = session.messages
  const contextChat = ongoingMessages.slice(-(parseInt(envVar("max_context")) || 40))

  if (provider.apiStyle === "anthropic") {
    const result = runCompleteChat(chatFile, "[continuation]", provider, systemPrompt, contextChat, timeoutSeconds)
    // 续答成功,清 pending
    runLocalAgentWithArguments(["--continuation-clear"])
    return result
  }

  // 流式路径(startStream): 由 caller 决定是否清 pending
  // 这里只返回触发 rerun + streaming
  const streamFile = `${envVar("alfred_workflow_cache")}/stream.txt`
  const pidStreamFile = `${envVar("alfred_workflow_cache")}/pid.txt`
  startStream(provider.endpoint, provider.apiKey, provider.model, systemPrompt, contextChat, streamFile, pidStreamFile, timeoutSeconds, provider.supportsThinkingParam)
  return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: "1" },
    response: markdownSession({ title: session.title, messages: ongoingMessages }),
    behaviour: { scroll: "end" }
  })
}

function formatUserLabel(labels) {
  return `# ⊙ ${labels.user}`
}

function formatAssistantLabel(labels) {
  return `# ⊚ ${labels.assistant}`
}

function markdownChat(messages, ignoreLastInterrupted = true) {
  const labels = chatLabels()

  return messages.reduce((accumulator, current, index, allMessages) => {
    if (current["role"] === "assistant")
      return `${accumulator}${demoteMarkdownHeadings(current["content"])}\n\n`

    if (current["role"] === "user") {
      const userMessage = `${formatUserLabel(labels)}\n\n${current["content"]}\n\n${formatAssistantLabel(labels)}`
      const userTwice = allMessages[index + 1]?.["role"] === "user"
      const lastMessage = index === allMessages.length - 1

      return userTwice || (lastMessage && !ignoreLastInterrupted) ?
        `${accumulator}${userMessage}\n\n[Answer Interrupted]\n\n` :
        `${accumulator}${userMessage}\n\n`
    }

    return accumulator
  }, "")
}

function markdownSession(session, ignoreLastInterrupted = true) {
  const header = session.title ? `## ⌖ ${session.title}\n\n---\n\n` : ""
  return `${header}${markdownChat(session.messages, ignoreLastInterrupted)}`
}

function markdownSessionWithDraft(chatFile, draftText) {
  const session = readSession(chatFile)
  const messages = session.messages.slice()
  if (messages.length > 0 && messages[messages.length - 1]["role"] === "user" && draftText)
    messages.push({ role: "assistant", content: draftText })

  return markdownSession({ title: session.title, messages }, false)
}

function outputTokenLimit() {
  const configured = parseInt(envVar("max_output_tokens"))
  return Number.isFinite(configured) && configured > 0 ? configured : 4096
}

function streamMaxSeconds(timeoutSeconds) {
  const configured = parseInt(envVar("stream_max_seconds"))
  if (Number.isFinite(configured) && configured > 0) return configured
  return Math.min(Math.max(timeoutSeconds * 4, 120), 300)
}

function streamIdleSeconds(timeoutSeconds) {
  const configured = parseInt(envVar("stream_idle_seconds"))
  if (Number.isFinite(configured) && configured > 0) return configured
  return Math.max(timeoutSeconds * 3, 90)
}

function skillsPrompt(query) {
  if (skillsPrompt._cache && skillsPrompt._cache.query === (query || "")) {
    return skillsPrompt._cache.value
  }
  const result = runLocalAgentWithArguments(["--skills-prompt", query || ""])
  let value = ""
  if (result && typeof result === "string" && result.trim().length > 0) {
    value = result.trim()
  }
  skillsPrompt._cache = { query: query || "", value: value }
  return value
}

function memoryPrompt() {
  const legacy = `${envVar("alfred_workflow_data")}/memory.json`
  const memDir = `${envVar("alfred_workflow_data")}/memories`
  if (fileExists(legacy) && !fileExists(`${memDir}/MEMORY.md`) && !fileExists(`${memDir}/USER.md`))
    runLocalAgentWithArguments(["--migrate-memory"])

  const result = runLocalAgentWithArguments(["--memory-prompt"])
  if (result && result.prompt && result.prompt.trim().length > 0)
    return result.prompt

  return ""
}

function soulPrompt() {
  runLocalAgentWithArguments(["--ensure-soul"])

  const result = runLocalAgentWithArguments(["--soul-prompt"])
  if (result && result.prompt && result.prompt.trim().length > 0)
    return result.prompt

  return ""
}

function runtimeGuardPrompt() {
  return [
    "【运行约束 · 最高优先级，与上文任何“主动去做”的指令冲突时以本节为准】",
    "你在一个单轮流式对话里运行：本次回复结束后没有自动续跑，你写下的任何「等会儿/接下来我会去做」的动作都不会真的发生。",
    "你实际拥有的能力（仅这些，由本地 Agent 在你回复前自动完成，你无法在回复中途临时调用）：",
    "- 读写 /Users/DRLer 下的本地文件、Obsidian 库；新增提醒；读写长期记忆。",
    "- 联网搜索 web_search（调 Tavily API，免费 1000 次/月，需在 [x] Workflow Env Vars 配 tavily_api_key）。",
    "- 网页抓取 web_fetch（调 baoyu-fetch CLI，需 bun + Chrome）。",
    "- 工具可以连续调用（web_search → web_fetch → web_search 再次搜细节），直到拿到完整信息。",
    "- 工具调用结束后会有一步「合成」:把原始搜索结果/网页 markdown 整理成简洁答案（这一步已由 runtimeGuard 强制:禁止瞎掰/禁止套用无关结果/必须标注来源）。",
    "你没有的能力（绝不要声称会去做）：",
    "- 跑未授权的本地 shell 命令、调未列出的外部服务、查未授权的数据库、等待后续结果。",
    "硬性输出规则：",
    "- 禁止用「我先看下…」「我去查一下」「让我并行查几个来源」「稍等/接下来我来…」这类只表态不给结果的句子作为整段回复或结尾。",
    "- 遇到工具暂时不可用（比如 tavily_api_key 没配、bun 没装）：直接告诉用户去哪配置，不要反复说不能联网。",
    "- 工具返回「未找到相关结果 / 0 条结果 / 网络错误 / 重试 2 次仍失败」时：直接告诉用户搜不到/失败，禁止用训练数据里的常识、其它剧/角色的印象、或通用模板去「补全」答案（典型反例：搜不到某角色时，凭印象编造演员/剧情/家庭关系）。",
    "- 工具结果与用户问题不直接相关时（如搜 A 角色却返回 B 角色的资料）：明确说「搜索结果中未找到 A 的相关信息，找到了 B 的相关资料：...」，让用户自己判断；不要把无关结果强行套到问题上。",
    "- 引用工具结果时显式标注来源（用「Tavily 搜索结果显示…」「搜索结果中提到…」这类措辞），不要把搜索结果伪装成「我从公开资料里看到…」这种凭空背书。",
    "- 每次回复都必须当场给出完整结论、可执行答案、或一个明确的问题；不要以冒号、引导语、未完成的计划收尾。"
  ].join("\n")
}

function composeSystemPrompt(systemPrompt, userQuery) {
  const soul = soulPrompt()
  const memory = memoryPrompt()
  const contextFile = loadContextFile()
  const skills = skillsPrompt(userQuery || "")
  return [soul, systemPrompt, contextFile, skills, memory, runtimeGuardPrompt()].filter(item => item && item.trim().length > 0).join("\n\n")
}

function loadContextFile() {
  const configured = (envVar("context_file_path") || "").trim()
  const vaultAgents = (envVar("obsidian_vault_path") || "").trim()
  const candidates = [
    configured,
    vaultAgents ? `${vaultAgents}/AGENTS.md` : ""
  ].filter(path => path && fileExists(path))

  if (candidates.length === 0) return ""

  const content = readFile(candidates[0]).trim()
  if (!content) return ""

  return [
    `以下是项目上下文（来自 ${candidates[0]}）：`,
    "",
    content
  ].join("\n")
}

function yamlScalar(value) {
  if (!value) return '""'
  if (/[:#\n"'[\]{}>|*&!%@`]/.test(value) || value.startsWith(" ") || value.endsWith(" "))
    return JSON.stringify(value)

  return value
}

function sanitizeFilename(name) {
  const cleaned = name
    .replace(/[\/\\:*?"<>|]/g, "-")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 80)

  return cleaned || "alfred-chat"
}

function uniqueExportPath(exportDir, baseName) {
  const stem = sanitizeFilename(baseName)
  let filePath = `${exportDir}/${stem}.md`

  if (!fileExists(filePath)) return filePath

  for (let index = 2; index < 100; index++) {
    filePath = `${exportDir}/${stem}-${index}.md`
    if (!fileExists(filePath)) return filePath
  }

  return `${exportDir}/${stem}.md`
}

function exportMarkdownSession(session) {
  const labels = chatLabels()
  const title = session.title ||
    session.messages.find(message => message["role"] === "user")?.["content"]?.split("\n")[0] ||
    "Alfred Chat"
  let body = `# ${title}\n\n`

  session.messages.forEach(message => {
    if (message["role"] === "user")
      body += `## ${labels.user}\n\n${message["content"]}\n\n`
    else if (message["role"] === "assistant")
      body += `## ${labels.assistant}\n\n${message["content"]}\n\n`
  })

  return { title, body }
}

function obsidianExportPaths() {
  const vaultPath = (envVar("obsidian_vault_path") || "/Users/DRLer/Obsidian_250614").replace(/\/$/, "")
  const exportFolder = (envVar("obsidian_export_folder") || "0.inbox").replace(/^\/|\/$/g, "")

  return {
    vaultPath,
    exportDir: `${vaultPath}/${exportFolder}`
  }
}

function responseWithConversation(chatFile, userText, assistantText, footer) {
  const session = readSession(chatFile)
  session.messages = session.messages.concat([
    { role: "user", content: userText },
    { role: "assistant", content: assistantText }
  ])
  writeSession(chatFile, session)

  return JSON.stringify({
    response: markdownSession(session, false),
    footer: footer,
    behaviour: { scroll: "end" }
  })
}

function localAgentScriptPath() {
  const cwd = $.NSFileManager.defaultManager.currentDirectoryPath.js
  const directPath = `${cwd}/local_agent.py`
  const workflowPath = `${cwd}/Workflow/local_agent.py`

  if (fileExists(directPath)) return directPath
  if (fileExists(workflowPath)) return workflowPath
  return "local_agent.py"
}

function workflowScriptPath(name) {
  const base = localAgentScriptPath().replace(/local_agent\.py$/, "")
  return `${base}${name}`
}

function spawnDetachedPython(scriptName, args) {
  const task = $.NSTask.alloc.init
  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [workflowScriptPath(scriptName)].concat(args || [])
  task.standardOutput = $.NSFileHandle.fileHandleWithNullDevice
  task.standardError = $.NSFileHandle.fileHandleWithNullDevice
  task.launchAndReturnError(false)
}

function maybeTriggerBackgroundReview(chatFile) {
  if (envVar("memory_auto_write") === "0") return

  const interval = parseInt(envVar("memory_nudge_interval")) || 10
  const turns = countTurns(readSession(chatFile).messages)
  if (turns === 0 || turns % interval !== 0) return

  spawnDetachedPython("background_review.py", [])
}

function maybeIndexSession() {
  spawnDetachedPython("session_index.py", [])
}

function runLocalAgentWithArguments(args) {
  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [localAgentScriptPath()].concat(args)
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  while (task.running && waitedMs < 5000) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return {
      handled: true,
      assistant_text: "本地 Agent 执行超时",
      footer: "本地 Agent 执行超时"
    }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return {
    handled: true,
    assistant_text: `本地 Agent 执行失败：${errorOutput || output}`,
