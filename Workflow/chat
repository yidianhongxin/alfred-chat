    "- 工具调用结束后会有一步「合成」:把原始搜索结果/网页 markdown 整理成简洁答案（这一步已由 runtimeGuard 强制:禁止瞎掰/禁止套用无关结果/必须标注来源）。",
    "你没有的能力（绝不要声称会去做）：",
    "- 跑未授权的本地 shell 命令、调未列出的外部服务、查未授权的数据库、等待后续结果。",
    "硬性输出规则：",
    "- 禁止用「我先看下…」「我去查一下」「让我并行查几个来源」「稍等/接下来我来…」这类只表态不给结果的句子作为整段回复或结尾。",
    "- 遇到工具暂时不可用（比如 tavily_api_key 没配、bun 没装）：直接告诉用户去哪配置，不要反复说不能联网。",
    "- 工具返回「未找到相关结果 / 0 条结果 / 网络错误 / 重试 2 次仍失败」时：直接告诉用户搜不到/失败，禁止用训练数据里的常识、其它剧/角色的印象、或通用模板去「补全」答案（典型反例：搜不到某角色时，凭印象编造演员/剧情/家庭关系）。",
    "- 工具结果与用户问题不直接相关时（如搜 A 角色却返回 B 角色的资料）：明确说「搜索结果中未找到 A 的相关信息，找到了 B 的相关资料：...」，让用户自己判断；不要把无关结果强行套到问题上。",
    "- 引用工具结果时显式标注来源（用「Tavily 搜索结果显示…」「搜索结果中提到…」这类措辞），不要把搜索结果伪装成「我从公开资料里看到…」这种凭空背书。",
    "- 每次回复都必须当场给出完整结论、可执行答案、或一个明确的问题；不要以冒号、引导语、未完成的计划收尾。"
  ].join("\n")
}

function composeSystemPrompt(systemPrompt, userQuery) {
  const soul = soulPrompt()
  const memory = memoryPrompt()
  const contextFile = loadContextFile()
  const skills = skillsPrompt(userQuery || "")
  return [soul, systemPrompt, contextFile, skills, memory, runtimeGuardPrompt()].filter(item => item && item.trim().length > 0).join("\n\n")
}

function loadContextFile() {
  const configured = (envVar("context_file_path") || "").trim()
  const vaultAgents = (envVar("obsidian_vault_path") || "").trim()
  const candidates = [
    configured,
    vaultAgents ? `${vaultAgents}/AGENTS.md` : ""
  ].filter(path => path && fileExists(path))

  if (candidates.length === 0) return ""

  const content = readFile(candidates[0]).trim()
  if (!content) return ""

  return [
    `以下是项目上下文（来自 ${candidates[0]}）：`,
    "",
    content
  ].join("\n")
}

function yamlScalar(value) {
  if (!value) return '""'
  if (/[:#\n"'[\]{}>|*&!%@`]/.test(value) || value.startsWith(" ") || value.endsWith(" "))
    return JSON.stringify(value)

  return value
}

function sanitizeFilename(name) {
  const cleaned = name
    .replace(/[\/\\:*?"<>|]/g, "-")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 80)

  return cleaned || "alfred-chat"
}

function uniqueExportPath(exportDir, baseName) {
  const stem = sanitizeFilename(baseName)
  let filePath = `${exportDir}/${stem}.md`

  if (!fileExists(filePath)) return filePath

  for (let index = 2; index < 100; index++) {
    filePath = `${exportDir}/${stem}-${index}.md`
    if (!fileExists(filePath)) return filePath
  }

  return `${exportDir}/${stem}.md`
}

function exportMarkdownSession(session) {
  const labels = chatLabels()
  const title = session.title ||
    session.messages.find(message => message["role"] === "user")?.["content"]?.split("\n")[0] ||
    "Alfred Chat"
  let body = `# ${title}\n\n`

  session.messages.forEach(message => {
    if (message["role"] === "user")
      body += `## ${labels.user}\n\n${message["content"]}\n\n`
    else if (message["role"] === "assistant")
      body += `## ${labels.assistant}\n\n${message["content"]}\n\n`
  })

  return { title, body }
}

function obsidianExportPaths() {
  const vaultPath = (envVar("obsidian_vault_path") || "/Users/DRLer/Obsidian_250614").replace(/\/$/, "")
  const exportFolder = (envVar("obsidian_export_folder") || "0.inbox").replace(/^\/|\/$/g, "")

  return {
    vaultPath,
    exportDir: `${vaultPath}/${exportFolder}`
  }
}

function responseWithConversation(chatFile, userText, assistantText, footer) {
  const session = readSession(chatFile)
  session.messages = session.messages.concat([
    { role: "user", content: userText },
    { role: "assistant", content: assistantText }
  ])
  writeSession(chatFile, session)

  return JSON.stringify({
    response: markdownSession(session, false),
    footer: footer,
    behaviour: { scroll: "end" }
  })
}

function localAgentScriptPath() {
  const cwd = $.NSFileManager.defaultManager.currentDirectoryPath.js
  const directPath = `${cwd}/local_agent.py`
  const workflowPath = `${cwd}/Workflow/local_agent.py`

  if (fileExists(directPath)) return directPath
  if (fileExists(workflowPath)) return workflowPath
  return "local_agent.py"
}

function workflowScriptPath(name) {
  const base = localAgentScriptPath().replace(/local_agent\.py$/, "")
  return `${base}${name}`
}

function spawnDetachedPython(scriptName, args) {
  const task = $.NSTask.alloc.init
  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [workflowScriptPath(scriptName)].concat(args || [])
  task.standardOutput = $.NSFileHandle.fileHandleWithNullDevice
  task.standardError = $.NSFileHandle.fileHandleWithNullDevice
  task.launchAndReturnError(false)
}

function maybeTriggerBackgroundReview(chatFile) {
  if (envVar("memory_auto_write") === "0") return

  const interval = parseInt(envVar("memory_nudge_interval")) || 10
  const turns = countTurns(readSession(chatFile).messages)
  if (turns === 0 || turns % interval !== 0) return

  spawnDetachedPython("background_review.py", [])
}

function maybeIndexSession() {
  spawnDetachedPython("session_index.py", [])
}

function runLocalAgentWithArguments(args) {
  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [localAgentScriptPath()].concat(args)
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  while (task.running && waitedMs < 5000) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return {
      handled: true,
      assistant_text: "本地 Agent 执行超时",
      footer: "本地 Agent 执行超时"
    }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return {
    handled: true,
    assistant_text: `本地 Agent 执行失败：${errorOutput || output}`,
    footer: "本地 Agent 执行失败"
  }

  try {
    return JSON.parse(output)
  } catch {
    return {
      handled: true,
      assistant_text: `本地 Agent 返回异常：${output}`,
      footer: "本地 Agent 返回异常"
    }
  }
}

function triggerCuratorTick() {
  // 异步(同步 spawn 但快速返回)调 --curator-tick,失败静默。
  // 减法版: 24h 节流在 curator.py 内部,这里只触发。
  try {
    const task = $.NSTask.alloc.init
    const stdout = $.NSPipe.pipe
    const stderr = $.NSPipe.pipe
    task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
    task.arguments = [localAgentScriptPath(), "--curator-tick"]
    task.standardOutput = stdout
    task.standardError = stderr
    task.launchAndReturnError(false)
    let waitedMs = 0
    while (task.running && waitedMs < 1500) {
      delay(0.05)
      waitedMs += 50
    }
    if (task.running) task.terminate()
  } catch (e) {
    // 静默:curator 失败不能影响主聊天
  }
}

function runLocalAgent(typedQuery) {
  return runLocalAgentWithArguments([typedQuery])
}

function runLocalAgentTool(toolCall) {
  return runLocalAgentWithArguments(["--tool", JSON.stringify(toolCall)])
}

function looksLikeSkillifyQuery(text) {
  const trimmed = text.trim()
  return /(?:生成|创建|提炼|固化|写成|整理成|做成|转成|转化为).*(?:skill|skills|Skill|技能)/i.test(trimmed) ||
    /(?:skill|skills|Skill|技能).*(?:生成|创建|提炼|固化|写成|整理成|做成)/i.test(trimmed) ||
    /^\/skillify/i.test(trimmed)
}

function looksLikeLocalAgentQuery(text) {
  const trimmed = text.trim()
  if (looksLikeSkillifyQuery(trimmed)) {
    return true
  }

  const fileHint = "([/\\\\]|(^|[\\s/\\\\])\\.env($|\\s)|\\.[A-Za-z0-9]{1,8}($|\\s))"

  return /^确认执行$/i.test(trimmed) ||
    /^(取消|取消执行)$/i.test(trimmed) ||
    /^(撤销上一步|undo last)$/i.test(trimmed) ||
    /^@\//.test(trimmed) ||
    /^(?:读取|查看|打开|写入|新建|创建|删除|追加|替换|列出|移动|总结)\s+\/Users\/DRLer\//i.test(trimmed) ||
    /^\/Users\/DRLer\/[^\s]*\s*$/i.test(trimmed) ||
    /桌面(?:上)?(?:新建|创建|写入|追加|附加|替换|删除|移除|读取|查看|列出|整理|移动)/i.test(trimmed) ||
    /(?:新建|创建|写入|追加|附加|替换|删除|移除|读取|查看|列出|整理|移动)(?:到)?桌面/i.test(trimmed) ||
    new RegExp(`(创建|新建|写入|追加|附加|替换|删除|移除|读取|查看).*${fileHint}`, "i").test(trimmed) ||
    new RegExp(`${fileHint}.*(内容|正文)[:：]`, "i").test(trimmed) ||
    /^(列出|新增|完成)任务/i.test(trimmed) ||
    /^记住/i.test(trimmed) ||
    /^(你)?记住/i.test(trimmed) ||
    /^列出记忆$/i.test(trimmed) ||
    /^(?:查看|列出|读取|显示)?灵魂$/i.test(trimmed) ||
    /(?:写入|更新|设定|追加)灵魂/i.test(trimmed) ||
    /(?:搜索|查找)(?:对话|聊天记录|历史)/i.test(trimmed) ||
    /(?:上次|之前).*(?:讨论|聊|说过|提到)/i.test(trimmed) ||
    /^搜索(?:OB|Obsidian|ob)/i.test(trimmed) ||
    // 去掉 /(?:OB|Obsidian|ob)库/ 的过宽匹配：之前会让"写入ob库"直接走本地 NLP agent,
    // 完全绕过 LLM 工具路由,导致 LLM 看不到对话历史瞎说"先确认再写入"却根本没调 obsidian_write.
    // 改由 mayNeedModelToolUse + decideToolUse 路由处理 (W7.10)
    /(?:新建|创建|写入)(?:一篇|一个|一份|到)?\s*(?:0\.inbox|10\.DL)/i.test(trimmed) ||
    /(?:列出|查看).*(?:0\.inbox|inbox).*(?:文章|文件|笔记)/i.test(trimmed) ||
    /(?:今天|今日)日记.*(内容|正文)[:：]/i.test(trimmed) ||
    /(?:翻阅|回顾|随便读|随机读|最近|近\s*\d+\s*(?:天|篇)).*(?:日记|OB|Obsidian|ob)/i.test(trimmed) ||
    /(读|读取|查看).*(OB|Obsidian|ob).*(今天|今日)日记/i.test(trimmed) ||
    /^(读|读取|查看)?(今天|今日)日记$/i.test(trimmed) ||
    /^运行命令[:：]/i.test(trimmed) ||
    /提醒/i.test(trimmed)
}

function handleLocalFileControl(chatFile, typedQuery) {
  if (!looksLikeLocalAgentQuery(typedQuery.trim())) return null

  const result = runLocalAgent(typedQuery)
  if (!result || !result.handled) return null

  return responseWithConversation(
    chatFile,
    typedQuery.trim(),
    result.assistant_text || "本地操作完成",
    result.footer || result.assistant_text || "本地操作完成"
  )
}

function runWorkflowPython(scriptName, args, timeoutSeconds) {
  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/python3")
  task.arguments = [workflowScriptPath(scriptName)].concat(args || [])
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  const limitMs = (timeoutSeconds || 30) * 1000
  while (task.running && waitedMs < limitMs) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return { error: "Python 脚本执行超时" }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return { error: errorOutput || output }

  try {
    return JSON.parse(output)
  } catch {
    return { error: output || "Python 脚本返回异常" }
  }
}

function runProviderBridgeComplete(provider, payload, timeoutSeconds) {
  const bridgePayload = {
    provider: provider.provider,
    model: payload.model || provider.model,
    messages: payload.messages || [],
    temperature: payload.temperature
  }
  const result = runWorkflowPython("provider_bridge.py", ["--complete", JSON.stringify(bridgePayload)], timeoutSeconds)
  if (result.error) return { error: result.error }
  return { content: result.content || "" }
}

function runChatCompletion(provider, payload, timeoutSeconds) {
  if (provider.apiStyle === "anthropic") {
    return runProviderBridgeComplete(provider, payload, timeoutSeconds)
  }

  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe
  const requestPayload = Object.assign({}, payload)

  if (provider.supportsThinkingParam && requestPayload.stream === false) {
    requestPayload.thinking = { type: "disabled" }
  }

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/curl")
  var curlArgs = [
    provider.endpoint,
    "--max-time", timeoutSeconds.toString(),
    "--silent",
    "--header", "Content-Type: application/json"
  ]
  if (provider.apiKey) curlArgs.push("--header", "Authorization: Bearer " + provider.apiKey)
  curlArgs.push("--data", JSON.stringify(requestPayload))
  task.arguments = curlArgs
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  while (task.running && waitedMs < timeoutSeconds * 1000) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return { error: "模型工具路由超时" }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return { error: errorOutput || output }

  try {
    const parsed = JSON.parse(output)
    const errorMessage = parsed["error"]?.["message"] || parsed["message"]
    if (errorMessage) return { error: errorMessage }
    return { content: parsed["choices"]?.[0]?.["message"]?.["content"] || "" }
  } catch {
    return { error: output }
  }
}

function extractJsonObject(text) {
  const trimmed = (text || "").trim()
  const fenced = trimmed.match(/```(?:json)?\s*([\s\S]*?)```/i)
  const candidate = fenced ? fenced[1].trim() : trimmed
  const start = candidate.indexOf("{")
  const end = candidate.lastIndexOf("}")
  if (start < 0 || end < start) return null

  try {
    return JSON.parse(candidate.slice(start, end + 1))
  } catch {
    return null
  }
}

function loadToolSchemas() {
  if (loadToolSchemas._cache) return loadToolSchemas._cache
  const result = runLocalAgentWithArguments(["--tool-schema"])
  if (!result || !result.handled) {
    loadToolSchemas._cache = []
    return loadToolSchemas._cache
  }
  try {
    const schemas = JSON.parse(result.assistant_text || "[]")
    loadToolSchemas._cache = Array.isArray(schemas) ? schemas : []
    return loadToolSchemas._cache
  } catch (e) {
    loadToolSchemas._cache = []
    return loadToolSchemas._cache
  }
}

