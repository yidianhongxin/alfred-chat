  } catch {
    return {
      handled: true,
      assistant_text: `本地 Agent 返回异常：${output}`,
      footer: "本地 Agent 返回异常"
    }
  }
}

function triggerCuratorTick() {
  // 异步(同步 spawn 但快速返回)调 --curator-tick,失败静默。
