    new RegExp(`(创建|新建|写入|追加|附加|替换|删除|移除|读取|查看).*${fileHint}`, "i").test(trimmed) ||
    new RegExp(`${fileHint}.*(内容|正文)[:：]`, "i").test(trimmed) ||
