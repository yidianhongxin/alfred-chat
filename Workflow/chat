function runChatCompletion(provider, payload, timeoutSeconds) {
  if (provider.apiStyle === "anthropic") {
    return runProviderBridgeComplete(provider, payload, timeoutSeconds)
  }

  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe
  const stderr = $.NSPipe.pipe
  const requestPayload = Object.assign({}, payload)

  if (provider.supportsThinkingParam && requestPayload.stream === false) {
    requestPayload.thinking = { type: "disabled" }
  }

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/curl")
  var curlArgs = [
    provider.endpoint,
    "--max-time", timeoutSeconds.toString(),
    "--silent",
    "--header", "Content-Type: application/json"
  ]
  if (provider.apiKey) curlArgs.push("--header", "Authorization: Bearer " + provider.apiKey)
  curlArgs.push("--data", JSON.stringify(requestPayload))
  task.arguments = curlArgs
  task.standardOutput = stdout
  task.standardError = stderr
  task.launchAndReturnError(false)

  let waitedMs = 0
  while (task.running && waitedMs < timeoutSeconds * 1000) {
    delay(0.05)
    waitedMs += 50
  }

  if (task.running) {
    task.terminate()
    return { error: "模型工具路由超时" }
  }

  const output = $.NSString.alloc.initWithDataEncoding(
    stdout.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js
  const errorOutput = $.NSString.alloc.initWithDataEncoding(
    stderr.fileHandleForReading.readDataToEndOfFile, $.NSUTF8StringEncoding).js

  if (task.terminationStatus !== 0) return { error: errorOutput || output }

  try {
    const parsed = JSON.parse(output)
    const errorMessage = parsed["error"]?.["message"] || parsed["message"]
    if (errorMessage) return { error: errorMessage }
    return { content: parsed["choices"]?.[0]?.["message"]?.["content"] || "" }
  } catch {
    return { error: output }
  }
}

