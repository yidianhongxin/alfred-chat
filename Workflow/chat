function decideToolUse(provider, typedQuery, timeoutSeconds) {
  // 注入最近 4 轮对话历史 (W7.10): 让 LLM 看到上轮的 web_search/web_fetch/tool 结果,
  // 才能在 obsidian_write args.content 里填入真实内容,避免"先 X 后 Y"的两步决策.
  const recentContext = (session && Array.isArray(session.messages)) ?
    session.messages.slice(-8) : []
  const historyMessages = recentContext
    .filter(m => m && (m.role === "user" || m.role === "assistant") && typeof m.content === "string" && m.content.trim().length > 0)
    .map(m => ({ role: m.role, content: m.content.length > 1500 ? m.content.slice(-1500) : m.content }))

  const result = runChatCompletion(provider, {
    model: provider.model,
    messages: [
      { role: "system", content: toolRouterPrompt() },
      ...historyMessages,
      { role: "user", content: typedQuery }
    ],
    stream: false,
    temperature: 0
  }, Math.min(timeoutSeconds, 10))

  if (result.error) return null

  const parsed = extractJsonObject(result.content)
  if (!parsed || !parsed.tool || parsed.tool === "none") return null
  if (!parsed.args) parsed.args = {}
  return parsed
}

function shouldFinalizeToolResult(toolCall, typedQuery) {
  const tool = toolCall?.tool || ""
  // web_search / web_fetch 永远合成: LLM 拿到原始 Tavily 输出/网页 markdown 后整理成干净答案
  if (["web_search", "web_fetch"].includes(tool)) return true
  // 其他工具需要用户明确说"总结/分析"才合成,否则直接显示原始结果
  return /总结|分析|解释|提取|根据|帮我|整理成|改写/i.test(typedQuery) &&
    ["read_file", "obsidian_daily_read", "obsidian_diary_browse", "obsidian_diary_recent", "obsidian_search", "obsidian_read", "obsidian_list", "obsidian_status", "session_search", "list_dir", "shell"].includes(tool)
}

function finalizeToolResult(provider, systemPrompt, typedQuery, toolResultText, timeoutSeconds) {
  const result = runChatCompletion(provider, {
    model: provider.model,
    messages: [
      { role: "system", content: systemPrompt || "你是一个有帮助的 AI 助手。" },
      { role: "user", content: [
        `用户原始请求：${typedQuery}`,
        "",
        "工具结果（原始）：",
        toolResultText,
        "",
        "【合成要求 · 务必遵守】",
        "1. 工具结果若说「未找到/0 条/网络错误/失败」,直接告诉用户搜不到/失败,不要用训练数据补全。",
        "2. 工具结果若与问题不直接相关,明确说「搜索结果中未找到 X 的相关信息」,不要强行套用。",
        "3. 引用工具结果时显式标注来源（用「Tavily 搜索结果显示…」「搜索结果中提到…」）,不要把搜索结果伪装成「我从公开资料里看到…」这种凭空背书。",
        "4. 整理成简洁的最终答案：1-3 段,关键事实用【】或加粗突出,带 1-2 条原始链接方便用户验证。",
        "5. 不要复述工具结果的 markdown 格式（标题/列表/编号）,用自然语言重新组织。"
      ].join("\n") }
    ],
    stream: false
  }, Math.min(timeoutSeconds, 30))

  return result.error ? `工具已执行，但模型总结失败：${result.error}\n\n${toolResultText}` : result.content
}

function handleModelToolUse(chatFile, typedQuery, provider, systemPrompt, timeoutSeconds) {
  if (!mayNeedModelToolUse(typedQuery.trim())) return null

  const maxIterations = parseInt(envVar("max_tool_iterations")) || 5
  let toolCall = decideToolUse(provider, typedQuery, timeoutSeconds)
  if (!toolCall) return null

  let iterations = 0
  let combinedText = ""
  let lastResult = null
  let lastTool = toolCall.tool

  while (toolCall && iterations < maxIterations) {
    const result = runLocalAgentTool(toolCall)
    if (!result || !result.handled) return null

    iterations++
    lastResult = result
    lastTool = toolCall.tool
    combinedText = combinedText ?
      `${combinedText}\n\n[${toolCall.tool}]\n${result.assistant_text || ""}` :
      (result.assistant_text || "本地工具已执行")

    if (result.status !== "success") break

    const followUpPrompt = [
      `用户原始请求：${typedQuery}`,
      `已完成工具：${toolCall.tool}`,
      `工具结果：${result.assistant_text || ""}`,
      "若还需要调用其他本地工具，只返回 JSON tool call；否则返回 {\"tool\":\"none\",\"args\":{}}"
    ].join("\n")

    const nextCall = decideToolUse(provider, followUpPrompt, timeoutSeconds)
    if (!nextCall || nextCall.tool === "none") break
    toolCall = nextCall
  }

  const hitLimit = iterations >= maxIterations && toolCall && toolCall.tool !== "none"
  const toolText = combinedText || "本地工具已执行"
  const assistantText = shouldFinalizeToolResult({ tool: lastTool }, typedQuery) && lastResult?.status === "success" ?
    finalizeToolResult(provider, systemPrompt, typedQuery, toolText, timeoutSeconds) :
    toolText

  const footer = hitLimit ?
    `已达工具迭代上限（${maxIterations}）` :
    (lastResult?.footer || assistantText)

  return responseWithConversation(
    chatFile,
    typedQuery.trim(),
    assistantText,
    footer
  )
}

function providerRequiresApiKey(provider) {
  return provider.provider !== "ollama"
}

function resolveProvider() {
