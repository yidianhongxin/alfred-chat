function looksLikeSkillifyQuery(text) {
  const trimmed = text.trim()
  return /(?:生成|创建|提炼|固化|写成|整理成|做成|转成|转化为).*(?:skill|skills|Skill|技能)/i.test(trimmed) ||
    /(?:skill|skills|Skill|技能).*(?:生成|创建|提炼|固化|写成|整理成|做成)/i.test(trimmed) ||
    /^\/skillify/i.test(trimmed)
}

